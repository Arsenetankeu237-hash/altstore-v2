# ============================================================
#  ALT STORE ERP v2 — Configuration (à copier vers .env)
#  ⚠️ Ne JAMAIS committer le fichier .env réel.
# ============================================================

# --- Base de données ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=u235742225_alt
DB_USER=root
DB_PASS=

# --- Application ---
APP_NAME="ALT STORE ERP"
APP_ENV=development            # development | production
APP_URL=http://localhost/altstore-v2
APP_DEBUG=true                 # false en production (masque les erreurs)

# --- Sécurité ---
# Chaîne aléatoire longue — générée une seule fois. Utilisée pour les tokens CSRF.
APP_KEY=CHANGER_PAR_UNE_CHAINE_LONGUE_ET_ALEATOIRE_64_CARACTERES

# --- Assistant IA (proxy serveur) ---
# La clé est lue côté serveur UNIQUEMENT (api/ia_proxy.php), jamais envoyée au navigateur.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Email (vérification inscription) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@altstore.ci
